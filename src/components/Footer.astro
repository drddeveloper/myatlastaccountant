---
import { Image } from 'astro:assets';
import { SITE_DATA } from '../data/constants';
import lightLogo from '../assets/images/branding/Atlas-Accounting-light-logo.svg';

const currentYear = new Date().getFullYear();
---

<footer class="bg-primary text-white">
  <div class="container mx-auto px-4 py-12 flex flex-col md:flex-row items-center justify-between gap-8">
    <a href="/" aria-label={`${SITE_DATA.company.name} — Home`}>
      <Image src={lightLogo} alt={`${SITE_DATA.company.name} logo`} class="h-14 w-auto" height={112} />
    </a>

    <div class="text-center text-sm space-y-3">
      <p>
        © {currentYear} {SITE_DATA.company.name}, a
        <a href={SITE_DATA.links.parentCompany} target="_blank" rel="noopener noreferrer" class="text-accent link">Lewis Group CPAs</a>
        company. All rights reserved
      </p>
      <p>
        <a href={`mailto:${SITE_DATA.company.email}`} class="text-accent link-hover">{SITE_DATA.company.email}</a>
      </p>
      <p class="text-xs text-white/60">
        <a href={SITE_DATA.links.siteCredits} target="_blank" rel="noopener noreferrer" class="link-hover">Site Credits: Deep River Digital</a>
      </p>
    </div>

    <a
      href={SITE_DATA.links.socials.instagram}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Atlas Accounting Group on Instagram"
      class="inline-flex items-center justify-center h-11 w-11 rounded-full border border-white/40 text-white hover:border-accent hover:text-accent transition-colors focus-visible:outline-2 focus-visible:outline-accent"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
        <rect x="3" y="3" width="18" height="18" rx="5" />
        <circle cx="12" cy="12" r="4" />
        <circle cx="17.2" cy="6.8" r="0.9" fill="currentColor" stroke="none" />
      </svg>
    </a>
  </div>
</footer>
