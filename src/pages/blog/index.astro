---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/sections/PageHero.astro';
import CalendlyEmbed from '../../components/CalendlyEmbed.astro';
import { SITE_DATA } from '../../data/constants';
import lightLogo from '../../assets/images/branding/Atlas-Accounting-light-logo.svg';
import ctaBgImg from '../../assets/images/home/Footer-CTA-card-background.jpg';

// Non-draft posts, newest first.
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const newsletterHref = `mailto:${SITE_DATA.company.email}?subject=${encodeURIComponent('Newsletter signup')}&body=${encodeURIComponent('Please add me to the Atlas Accounting Group newsletter.')}`;
---

<BaseLayout
  title="Blog"
  description="Accounting updates, tips, and practical guides to help contractors and specialty trade owners become more financially savvy."
>

  <PageHero
    theme="navy"
    eyebrow="Blog"
    title="Learn from us"
    subtitle="We post regular accounting updates, tips & tricks to help you become a more financially savvy business owner."
  />

  <section class="bg-cream">
    <div class="container mx-auto px-4 py-16 md:py-24">
      {posts.length > 0 ? (
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <a
              href={`/blog/${post.id}/`}
              class="bg-base-100 border border-base-300 group flex flex-col overflow-hidden transition-transform duration-300 hover:-translate-y-2 focus-visible:outline-2 focus-visible:outline-accent"
            >
              {post.data.image ? (
                <Image src={post.data.image} alt="" inferSize class="w-full aspect-video object-cover" />
              ) : (
                <div class="w-full aspect-video bg-primary flex items-center justify-center">
                  <Image src={lightLogo} alt="" class="h-14 w-auto opacity-80" height={112} />
                </div>
              )}
              <div class="p-6 flex flex-col flex-grow">
                <time datetime={post.data.pubDate.toISOString()} class="text-sm text-base-content">
                  {formatDate(post.data.pubDate)}
                </time>
                <h2 class="heading-display text-xl text-primary mt-2 group-hover:text-accent-ink transition-colors">
                  {post.data.title}
                </h2>
                <p class="mt-3 text-sm leading-relaxed flex-grow">{post.data.description}</p>
                <span class="mt-4 inline-block text-accent-ink font-semibold text-sm uppercase tracking-wide">Read more →</span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="max-w-2xl mx-auto text-center">
          <h2 class="heading-display text-2xl text-primary">New posts are on the way</h2>
          <p class="mt-4 text-lg leading-relaxed">We're writing our first articles now. Check back soon — or book a call and get your questions answered in person.</p>
          <div class="mt-8">
            <a href="/getting-started/" class="btn btn-accent">Book a Call</a>
          </div>
        </div>
      )}
    </div>
  </section>

  {/* Newsletter band — mirrors the live "Want tips straight in your inbox?" section.
      TODO (client): the live site uses a Gravity Form; wire this to the leadflow
      system's form endpoint when available. Until then the CTA opens a prefilled email. */}
  <section class="bg-cream-dark">
    <div class="container mx-auto px-4 py-14 md:py-16 text-center">
      <h2 class="heading-display text-2xl md:text-3xl text-primary">Want tips straight in your inbox?</h2>
      <p class="mt-3 max-w-xl mx-auto">Get accounting tips for the trades, no spam, unsubscribe anytime.</p>
      <div class="mt-6">
        <a href={newsletterHref} class="btn btn-accent">Sign Me Up</a>
      </div>
    </div>
  </section>

  {/* Book-a-call closer — same treatment as the homepage */}
  <section class="bg-accent relative overflow-hidden">
    <Image src={ctaBgImg} alt="" class="absolute inset-0 w-full h-full object-cover object-top" widths={[1280]} sizes="100vw" aria-hidden="true" />
    <div class="absolute inset-0 bg-gradient-to-b from-black/25 to-transparent pointer-events-none"></div>
    <div class="container mx-auto px-4 py-16 md:py-20 relative">
      <h2 class="heading-display text-3xl md:text-4xl text-white text-center max-w-3xl mx-auto">
        Find out how we can help your trade business
      </h2>
      <div class="mt-10 max-w-3xl mx-auto bg-base-100 shadow-xl">
        <CalendlyEmbed />
      </div>
    </div>
  </section>

</BaseLayout>
