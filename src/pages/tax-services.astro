---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/sections/PageHero.astro';
import SectionHeading from '../components/sections/SectionHeading.astro';
import CtaBand from '../components/sections/CtaBand.astro';
import Testimonial from '../components/sections/Testimonial.astro';
import { SITE_DATA } from '../data/constants';

// Positioning note: Atlas does NOT file taxes directly — it coordinates with
// external, industry-specific tax CPAs. Keep this framing intact in all copy.

const partnershipColumns = [
  {
    title: 'Partner with tax experts',
    body: 'We work strategically with construction and specialty trade CPAs so you keep more of what you earn. Smart planning, not shortcuts.',
  },
  {
    title: 'Gain year-round support',
    body: 'Every Atlas plan includes year-round advisory support, so the financial decisions you make in June are just as tax-efficient as the ones you make in April.',
  },
  {
    title: 'Save money with industry expertise',
    body: 'Generalist tax accountants routinely miss deductions and credits specific to the trades. Our industry-focused partners make sure every saving your business qualifies for is captured.',
  },
];

const processSteps = [
  { num: '01', title: 'We Finalize Accurate Deductions & Reports', body: 'Because your books stay current all year, we hand your tax specialist clean, complete numbers — deductions identified, reports finalized.' },
  { num: '02', title: 'Tax Experts File & Submit Your Taxes', body: 'Our partner CPAs handle the full compliance work: federal and state income tax returns, sales tax, payroll tax, property tax, and excise tax.' },
  { num: '03', title: 'Together, We Maximize Your Business Potential', body: 'Filing is the finish line, not the goal. We fold what we learn each season back into your strategy for the year ahead.' },
];
---

<BaseLayout
  title="Tax Services for Contractors"
  description="Atlas Accounting Group keeps your books tax-ready all year and coordinates with industry-specific tax CPAs who file for you — no surprises at tax time."
>

  {/* Live-site defect fixed here: the original page rendered its hero heading as an
      <h2>. PageHero outputs a proper <h1>. */}
  <PageHero
    theme="cream"
    eyebrow="Tax"
    title="Ditch the tax stress with Atlas Accounting Group"
    subtitle="Tax season stops being scary when your bookkeeping, advisory, and payroll live under one roof. We keep your books current all year long, so there are no nasty surprises waiting for you in April."
    ctaLabel="Book Your Discovery Call"
    ctaHref={SITE_DATA.links.bookACall}
    secondaryLabel="See Pricing"
    secondaryHref="/pricing/"
  />

  <section class="bg-base-100">
    <div class="container mx-auto px-4 py-16 md:py-24">
      <SectionHeading
        eyebrow="How it works"
        title="We work seamlessly with your tax accountant"
        intro="We partner with industry-specific tax specialists who provide full tax compliance services — federal and state income tax returns, sales tax, payroll tax, property tax, and excise tax. Atlas prepares the numbers; the specialists file."
        align="center"
      />
      <div class="mt-12 grid gap-8 md:grid-cols-3">
        {partnershipColumns.map((col) => (
          <div class="card border border-base-300 shadow-none">
            <h3 class="heading-display text-lg text-primary">{col.title}</h3>
            <p class="mt-3 leading-relaxed">{col.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-cream">
    <div class="container mx-auto px-4 py-16 md:py-24 grid gap-12 lg:grid-cols-2 lg:items-center">
      <SectionHeading
        eyebrow="Start here"
        title="Are your books a mess?"
        intro="Messy, incomplete, long-overdue books are our starting point every week — we expect them. Wiping the slate clean is the job. Our ongoing bookkeeping keeps your numbers accurate and up to date from here forward, which is exactly what makes tax time painless."
      />
      <div class="lg:justify-self-end">
        {/* Live page links to /bookkeeper-for-construction/, which doesn't exist in
            this rebuild — routing to the construction industry page instead. */}
        <a href="/construction-accountants/" class="btn btn-accent">Learn More</a>
      </div>
    </div>
  </section>

  <section class="bg-primary">
    <div class="container mx-auto px-4 py-16 md:py-24">
      <SectionHeading
        onDark
        eyebrow="The process"
        title="How our tax partnership works"
        align="center"
      />
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {processSteps.map((step) => (
          <div class="card bg-white/5 border border-white/15 shadow-none">
            <span class="heading-display text-3xl text-sky" aria-hidden="true">{step.num}</span>
            <h3 class="heading-display text-lg text-white mt-3">{step.title}</h3>
            <p class="mt-3 text-white/80 leading-relaxed">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-base-100">
    <div class="container mx-auto px-4 py-16 md:py-24 grid gap-12 lg:grid-cols-2">
      <div>
        <SectionHeading
          eyebrow="Strategy"
          title="Focus on your long-term financial success"
        />
        <p class="mt-4 text-lg leading-relaxed max-w-prose">We start from where your business actually stands today, then build the accounting support around your short- and long-term goals: comprehensive tax strategy, forecasting, cash-flow support, and strategic advisory work — all aimed at getting your business performing at its full potential.</p>
      </div>
      <div>
        <SectionHeading
          eyebrow="Optimization"
          title="Keep taxes as low as legally possible"
        />
        <p class="mt-4 text-lg leading-relaxed max-w-prose">If your tax advice comes from a generic, stuck-in-the-1990s accountant, it's probably as dated as their office decor. Our tax partnership tracks the latest industry-specific grants, deductions, and credits each year — down to the last cent.</p>
      </div>
    </div>
  </section>

  <section class="bg-cream">
    <div class="container mx-auto px-4 py-16 md:py-24">
      <div class="max-w-3xl mx-auto">
        <SectionHeading
          eyebrow="Client story"
          title="“I now have a full understanding of my financial position.”"
          align="center"
        />
        <div class="mt-10">
          <Testimonial
            quote="Working with Atlas Accounting Group has completely changed the outlook of my business. I knew very little about the financial health of my company when we started. Now I have a full understanding of my financial position and can make educated business decisions instead of basing them on guesses and feelings."
            name="Ryann Blake"
            role="Owner, Chimney Techniques"
          />
        </div>
      </div>
    </div>
  </section>

  <CtaBand
    heading="Find out how we can help your construction business"
    ctaLabel="Book Your Discovery Call"
  />

</BaseLayout>
