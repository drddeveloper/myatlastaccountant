---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBand from '../components/sections/CtaBand.astro';

import chrisImg from '../assets/images/pages/team/Chris-Lewis-CPA-SEO.jpg';
import jennyImg from '../assets/images/pages/team/Jenny-Page.jpg';
import nicoleImg from '../assets/images/pages/team/Construction-Accountant_Nicole.png';
import lizImg from '../assets/images/pages/team/Liz_Construction-Accountant.png';
import madisonImg from '../assets/images/pages/team/Madison_Construction-Accountant.webp';

// Live page parity: 5 members, each a full-width row (circular photo left,
// name + title + bio right). Copy is verbatim from the live loop items.
const team = [
  {
    name: 'Chris Lewis, CPA',
    title: 'CEO',
    photo: chrisImg,
    alt: 'Chris Lewis CPA headshot',
    bio: [
      'Chris Lewis is the CEO of Atlas Accounting Group, taking the helm from Mackenzie Gray to continue Atlas’s mission of delivering elite, industry-specific financial support for contractors and specialty trades. As the founder of Lewis Group CPAs, which acquired Atlas in 2026, Chris saw a perfect match between the two firms. His goal is to give contractors a full financial team: Atlas’s day-to-day operational mastery combined with Lewis Group’s heavy-hitting tax strategy.',
      'Though his official title is CEO, Chris usually describes his role as “machine operator and master juggler.” He is fiercely passionate about helping clients scale their businesses and equally dedicated to helping his staff develop their skills. Chris is a leader who proves that work-life balance actually drives growth. Years ago, he pitched a firm-wide 4-day workweek for eight months out of the year so staff could enjoy three-day weekends. Despite initial skepticism, the team loved it. The firm grew more that year than ever before. He brings that same innovative, people-first philosophy to the Atlas team.',
    ],
  },
  {
    name: 'Jenny Page',
    title: 'Senior Accountant',
    photo: jennyImg,
    alt: 'Jenny Page headshot',
    bio: [
      'Jenny is a Senior Accountant at Atlas Accounting Group with 20 years of experience across different trade industries. Her expertise includes bookkeeping, financial reporting and analysis, and reconciliations, ensuring accurate and insightful financial management for our clients. Based in sunny Florida, Jenny enjoys spending her free time outdoors boating, camping, and tending to her garden, where she takes pride in growing many fruits and veggies (peppers and sweet potatoes in particular).',
    ],
  },
  {
    name: 'Nicole Orlando',
    title: 'Senior Accountant',
    photo: nicoleImg,
    alt: 'Nicole Orlando',
    bio: [
      // Live copy ends without a period — added per typo-fix policy.
      'Nicole is a Senior Accountant at Atlas Accounting Group with 23 years of experience in the field, including 17 years in corporate accounting and 6 years working with small businesses. Her expertise spans bookkeeping, financial reporting and analysis, and reconciliations, providing clients with accurate and insightful financial management. A natural auditor with a keen eye for detail, Nicole thrives on uncovering the finer points that ensure excellence in her work. Outside of the office, Nicole is an avid traveler and outdoor enthusiast who has explored 49 states, with Alaska next on her list. She enjoys camping, road trips, and hunting for unique finds while antiquing, combining her love of adventure with a passion for the past.',
    ],
  },
  {
    name: 'Liz Collazo',
    title: 'Payroll Specialist',
    photo: lizImg,
    alt: 'Liz Collazo',
    bio: [
      'Liz is our Payroll Specialist at Atlas Accounting Group, ensuring client employees are paid accurately and on time while maintaining compliance with state tax regulations. She manages wage calculations, 401(k) reporting, and employee updates, providing seamless payroll services for our clients. With 25 years of accounting experience, Liz also previously served as a director in a mental health facility for 7 years. Outside of work, Liz loves spending time at the beach, enjoying date nights and meals with her husband, and relaxing to her favorite music.',
    ],
  },
  {
    name: 'Madison Maxwell',
    title: 'Client Success & Marketing Coordinator',
    photo: madisonImg,
    alt: 'Madison Maxwell',
    bio: [
      'Madison is the Client Success and Marketing Coordinator at Atlas Accounting Group, dedicated to fostering strong relationships with clients and ensuring they get the most out of the accounting systems we’ve tailored for them. She also creates valuable resources to support both current and prospective clients. With 10 years of experience in customer service, project management, client success, and marketing for non-profits and small businesses, Madison brings a wealth of expertise and a personal touch to her role. When she’s not working, Madison loves traveling to new destinations, whether across the country or overseas, and is currently living in NYC immersing herself in the vibrant food scene and lively atmosphere.',
    ],
  },
];
---

<BaseLayout
  title="Meet the Team"
  description="Meet your dedicated team of expert accountants specializing in helping contractors and specialty trades businesses like yours grow and thrive"
>

  {/* ── Hero — white, centered (live section 12b0035) ── */}
  <section class="bg-base-100">
    <div class="container mx-auto px-4 pt-14 pb-14 md:pt-28 md:pb-20">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="heading-display text-4xl md:text-6xl text-secondary">Meet the Atlas Team</h1>
        <p class="mt-6 text-lg leading-relaxed">
          At Atlas Accounting Group, our team is the foundation of your success. Each member brings expertise, dedication, and a personal touch to ensure you get the best service possible. Collectively, with over 100 years of experience in accounting for the home services and construction industry, Mackenzie and the Atlas team have earned their reputation as trusted experts for their financial precision, understanding of proper accounting workflows, and innovative approach to client efficiency.
        </p>
      </div>
    </div>
  </section>

  {/* ── Team — cream, one full-width row per member (live loop grid 3829c97) ── */}
  <section class="bg-cream">
    <div class="container mx-auto px-4 py-16 md:py-24">
      <div class="max-w-6xl mx-auto grid gap-y-14 md:gap-y-16">
        {team.map((member, i) => (
          <article class="grid gap-8 md:grid-cols-[330px_1fr] md:gap-12 md:items-center">
            <Image
              src={member.photo}
              alt={member.alt}
              class="w-full h-auto rounded-full"
              widths={[330, 660]}
              sizes="(min-width: 768px) 330px, 100vw"
              loading={i === 0 ? 'eager' : 'lazy'}
            />
            <div>
              <h2 class="font-heading font-bold text-3xl md:text-4xl text-secondary leading-tight">{member.name}</h2>
              <p class="eyebrow text-base md:text-lg mt-2">{member.title}</p>
              <div class="mt-5 space-y-4 leading-relaxed">
                {member.bio.map((para) => <p>{para}</p>)}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* Live pages end with the global footer CTA band ("Find out how we can
      help your trade business" + Calendly); the rebuild represents it
      with the shared CtaBand, as on the other rebuilt pages. */}
  <CtaBand heading="Find out how we can help your trade business" />

</BaseLayout>
