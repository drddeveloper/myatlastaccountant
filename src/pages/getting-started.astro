---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import CalendlyEmbed from '../components/CalendlyEmbed.astro';

import heroImg from '../assets/images/pages/getting-started/Accountant-for-Contractors.webp';
import iconLaptop from '../assets/images/pages/getting-started/person-with-laptop-icon.svg';
import iconBookCall from '../assets/images/pages/getting-started/book-a-call-icon.svg';
import iconRocket from '../assets/images/pages/getting-started/rocket-icon.svg';

// This is the site's primary conversion page — the sitewide "Book a Call" CTA
// points here, and (matching the live site) the shared footer Calendly band is
// omitted because the page embeds its own scheduler.
const steps = [
  {
    icon: iconLaptop,
    title: 'Tell us about yourself',
    body: 'Answer just a few short questions to tell us about your company so that we can prepare for our quick call.',
  },
  {
    icon: iconBookCall,
    title: 'Book 45-min free consultation',
    body: 'Jump on a call with one of our team members so we can discuss what problems you are having and how we can help solve them!',
  },
  {
    icon: iconRocket,
    title: 'Kick off!',
    body: 'If it’s a great fit for both of us, we’ll send you a proposal and a few onboarding documents to get started. It’s that easy!',
  },
];
---

<BaseLayout
  title="Book a Call with Construction Accountants"
  description="At Atlas Accounting group, we help grow your construction business. Book a complimentary 45-minute call with one of our construction accountants and get help with any financial concerns you have."
>

  {/* ── Hero — white, text left / photo right (mirrors live section 2ba9169e) ── */}
  <section class="bg-base-100">
    <div class="container mx-auto px-4 grid gap-10 lg:grid-cols-2 lg:items-stretch">
      <div class="pt-14 pb-4 md:pt-24 lg:py-28 lg:self-center">
        <h1 class="heading-display text-4xl md:text-5xl xl:text-6xl text-secondary">
          Ready to <span class="text-sky-ink">move forward?</span>
        </h1>
        <p class="mt-6 text-lg leading-relaxed max-w-xl">
          We’re excited to meet you! Let’s discuss a few things to make sure it’s the best fit for both of us first.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="#calendly" class="btn btn-accent">Schedule Discovery Call</a>
          <a href="tel:3609000421" class="btn btn-primary">Call (360) 900-0421</a>
        </div>
      </div>
      <div class="lg:self-end">
        <Image
          src={heroImg}
          alt="Construction accountant smiling while on a call at her desk"
          class="w-full h-auto block"
          widths={[480, 768, 900]}
          sizes="(min-width: 1024px) 45vw, 100vw"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </section>

  {/* ── Calendly — pale-peach panel on the cream canvas (live 16ba9b2 → 84d0cd9) ── */}
  <section id="calendly" class="bg-cream scroll-mt-24">
    <div class="container mx-auto px-4 py-16 md:py-24">
      <div class="bg-cream-dark px-5 py-8 md:p-10">
        <h2 class="heading-display text-3xl md:text-4xl text-secondary text-center max-w-3xl mx-auto">
          <span class="text-sky-ink">Choose a time</span> to chat to get started:
        </h2>
        <div class="mt-8 max-w-3xl mx-auto bg-base-100 shadow-xl">
          <CalendlyEmbed />
        </div>
      </div>
    </div>
  </section>

  {/* ── What happens next — three bordered step cards (live e7f6971) ── */}
  <section class="bg-cream">
    <div class="container mx-auto px-4 pb-16 md:pb-24">
      <h2 class="heading-display text-3xl md:text-4xl text-secondary text-center">
        What <span class="text-sky-ink">happens next</span>?
      </h2>
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {steps.map((step) => (
          <div class="bg-base-100 border border-base-300 hover:border-accent transition-colors p-8 md:p-10">
            <Image src={step.icon} alt="" class="h-20 w-20" width={90} height={90} aria-hidden="true" />
            <h3 class="text-2xl font-bold text-secondary mt-6">{step.title}</h3>
            <p class="mt-3 leading-relaxed">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
