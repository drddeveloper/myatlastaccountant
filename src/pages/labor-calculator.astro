---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import CalendlyEmbed from '../components/CalendlyEmbed.astro';

import heroImg from '../assets/images/pages/labor-calc/Bookkeeping-for-electricians.png';
import ctaBgImg from '../assets/images/home/Footer-CTA-card-background.jpg';

// Input definitions drive both the form markup and keep IDs consistent with
// the live site's calculator script. `cols` mirrors the live widget's
// flex-4 (2-up) / flex-3 (3-up) input row layouts.
const inputGroups = [
  {
    legend: 'Employee Pay Inputs',
    helper: 'Set working hours and pay rates. OT is optional.',
    cols: 2,
    fields: [
      { id: 'working_hours', label: 'Working hours per year', value: 1880 },
      { id: 'base_rate', label: 'Base hourly rate ($)', value: 30 },
      { id: 'ot_hours', label: 'OT hours', value: 0 },
      { id: 'ot_rate', label: 'OT rate ($)', value: 0 },
    ],
  },
  {
    // Live-site typo fixed deliberately: "they use" → "They use".
    legend: 'Non-working wages',
    helper: 'These hours are paid, but not billable. They use the base hourly rate.',
    cols: 3,
    fields: [
      { id: 'holiday_hours', label: 'Holiday hours', value: 80 },
      { id: 'pto_hours', label: 'PTO hours', value: 80 },
      { id: 'sick_hours', label: 'Sick hours', value: 40 },
    ],
  },
  {
    legend: 'Payroll taxes & benefits (annual)',
    helper: 'Social Security (6.2%) and Medicare (1.45%) calculate automatically. Enter annual amounts for the rest.',
    cols: 2,
    fields: [
      { id: 'workers_comp', label: 'Workers comp ($)', value: 2200 },
      { id: 'state_unemployment', label: 'State unemployment ($)', value: 1150 },
      { id: 'retirement', label: 'Retirement ($)', value: 1872 },
      { id: 'health_insurance', label: 'Health insurance ($)', value: 5000 },
    ],
  },
];

// The four headline metric cards, stacked in the results panel like the live widget.
const headlineMetrics = [
  { id: 'billable_hours', label: 'Billable hours', caption: 'Working hours × efficiency' },
  { id: 'break_even', label: 'Break-even labor rate', caption: 'Annual total cost ÷ billable hours' },
  { id: 'hourly_cost', label: 'Hourly labor cost', caption: 'Annual total cost ÷ 2,080' },
  { id: 'overhead_pct', label: 'Overhead on wages', caption: 'Total burden ÷ working wages' },
];

const breakdownRows = [
  { id: 'working_wages', label: 'Working Wages' },
  { id: 'non_working_wages', label: 'Non-Working Wages' },
  { id: 'payroll_taxes', label: 'Payroll Taxes' },
  { id: 'benefits_total', label: 'Benefits' },
  { id: 'burden_cost', label: 'Additional Cost Beyond Wages', rule: true },
  { id: 'annual_total', label: 'Annual Total Cost' },
];
---

{/* Title/meta carried over verbatim from the live page. The live meta
    description is truncated mid-sentence ("…benefits, and") — flagged for
    client review, kept as-is for parity. */}
<BaseLayout
  title="Labor Calculator"
  description="This calculator helps you see the real hourly cost of one employee, not just their base pay. It factors in paid time off, payroll taxes, benefits, and"
>

  {/* ── Hero (live: white, two columns, blue "calculator", navy button → #calculator) ── */}
  <section class="bg-base-100">
    <div class="container mx-auto px-4 py-14 md:py-24 grid gap-10 lg:grid-cols-2 lg:items-center">
      <div>
        <h1 class="heading-display text-4xl md:text-5xl xl:text-6xl text-primary">
          Labor cost <span class="text-sky-ink">calculator</span>
        </h1>
        <p class="mt-6 text-lg leading-relaxed max-w-xl">
          This calculator helps you see the real hourly cost of one employee, not just their base pay. It factors in paid time off, payroll taxes, benefits, and non-billable time so you can set accurate labor rates and pricing.
        </p>
        <div class="mt-8">
          <a href="#calculator" class="btn btn-accent">Try Calculator</a>
        </div>
      </div>
      <Image
        src={heroImg}
        alt="Bookkeeping for electricians"
        class="w-full h-auto"
        widths={[400, 800]}
        sizes="(min-width: 1024px) 45vw, 100vw"
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </section>

  {/* ── Calculator (live: cream section; white input cards with sky border on the
       left, white results card with orange border on the right) ── */}
  <section class="bg-cream" id="calculator">
    <div class="container mx-auto px-4 py-16 md:py-24">
      <div class="grid gap-8 lg:grid-cols-5 lg:items-start">

        <form id="labor-form" novalidate class="lg:col-span-3">
          {inputGroups.map((group) => (
            <fieldset class="bg-base-100 border border-sky p-6 md:p-8 mb-6 md:mb-8">
              {/* float-left keeps the legend inside the card instead of notching the fieldset border */}
              <legend class="float-left w-full heading-display text-lg text-secondary">{group.legend}</legend>
              <p class="clear-both mt-1.5 mb-5 text-sm">{group.helper}</p>
              <div class={`grid gap-4 ${group.cols === 3 ? 'sm:grid-cols-3' : 'sm:grid-cols-2'}`}>
                {group.fields.map((f) => (
                  <div>
                    <label for={f.id} class="block font-semibold text-sm text-secondary mb-1.5">{f.label}</label>
                    <input class="input" type="number" id={f.id} name={f.id} value={f.value} min="0" inputmode="decimal" />
                  </div>
                ))}
              </div>
            </fieldset>
          ))}

          <fieldset class="bg-base-100 border border-sky p-6 md:p-8">
            <legend class="float-left w-full heading-display text-lg text-secondary">Billing assumptions</legend>
            <p class="clear-both mt-1.5 mb-5 text-sm">What percentage of working hours are truly billable time on a job?</p>
            <div>
              <label for="efficiency" class="block font-semibold text-sm text-secondary mb-1.5">Billable Efficiency (0-1)</label>
              <input class="input" type="number" id="efficiency" name="efficiency" value="0.5" step="0.01" min="0" max="1" inputmode="decimal" />
            </div>
          </fieldset>
          {/* The live "Calculate" button (an anchor to #results) is intentionally
              dropped — results update live on every input. */}
        </form>

        {/*
          The live site hides this panel behind a name/email Gravity Forms gate.
          Per the theme JS, that gate is purely cosmetic — calculations run
          client-side on every input regardless, and the form submit just
          removes a CSS overlay. We intentionally drop the gate and show
          results immediately.
        */}
        <div class="lg:col-span-2 bg-base-100 border border-accent p-6 md:p-8 lg:sticky lg:top-8" id="results">
          {/* h2, not the live h3 — fieldset legends aren't headings, so this keeps the outline h1 → h2 */}
          <h2 class="heading-display text-lg text-secondary">Results</h2>
          <p class="mt-1.5 text-sm">Live calculations based on your inputs.</p>

          <div aria-live="polite">
            {headlineMetrics.map((m) => (
              <div class="mt-5 bg-cream p-5">
                <p class="text-sm font-semibold uppercase tracking-wide text-secondary">{m.label}</p>
                <p class="heading-display text-3xl text-accent-ink mt-2" id={m.id}>—</p>
                <p class="text-sm mt-2">{m.caption}</p>
              </div>
            ))}

            <dl class="mt-5 bg-cream-dark p-5 flex flex-col gap-2">
              {/* the divider mirrors the live <hr> before "Additional Cost Beyond
                  Wages"; a border keeps the <dl> content model valid */}
              {breakdownRows.map((row) => (
                <div class={`flex items-baseline justify-between gap-4 ${row.rule ? 'border-t border-base-300 mt-1 pt-3' : ''}`}>
                  <dt class="text-sm uppercase tracking-wide">{row.label}</dt>
                  <dd class="font-bold text-primary" id={row.id}>—</dd>
                </div>
              ))}
            </dl>
          </div>
        </div>

      </div>

      {/* ── Excel upsell (live: white block nested inside the cream section) ── */}
      <div class="mt-16 md:mt-24 max-w-3xl mx-auto bg-base-100 px-6 py-10 md:px-12 md:py-14 text-center">
        <h2 class="heading-display text-3xl md:text-4xl text-secondary">Want the full Excel tool for all employees?</h2>
        <p class="mt-4 leading-relaxed">
          The online preview is designed for one employee. If you want to build rates for every employee and keep the file on record, grab the full calculator with all equations included.
        </p>
        <div class="mt-8 flex flex-wrap gap-4 justify-center">
          <a href="https://myatlasaccountant.mykajabi.com/labor-burden-calculator" target="_blank" rel="noopener" class="btn btn-accent">Buy the Excel calculator</a>
          <a href="#calendly" class="btn btn-outline">Talk to us about implementation</a>
        </div>
      </div>
    </div>
  </section>

  {/* ── Book a call (live footer band: orange duotone photo card + inline Calendly;
       same treatment as the homepage's canonical version) ── */}
  <section class="bg-accent relative overflow-hidden" id="calendly">
    <Image src={ctaBgImg} alt="" class="absolute inset-0 w-full h-full object-cover object-top" widths={[1280]} sizes="100vw" aria-hidden="true" />
    <div class="absolute inset-0 bg-gradient-to-b from-black/25 to-transparent pointer-events-none"></div>
    <div class="container mx-auto px-4 py-16 md:py-20 relative">
      <h2 class="heading-display text-3xl md:text-4xl text-white text-center max-w-3xl mx-auto">
        Find out how we can help your trade business
      </h2>
      <div class="mt-10 max-w-3xl mx-auto bg-base-100 shadow-xl">
        <CalendlyEmbed />
      </div>
    </div>
  </section>

  <script>
    // Formulas transcribed from the live site's theme script
    // (/wp-content/themes/atlasaccounting/script.js). The fixed 2,080-hour
    // divisor for "Hourly labor cost" is intentional — it mirrors the live site.
    const num = (id: string): number => {
      const el = document.getElementById(id) as HTMLInputElement | null;
      return el ? parseFloat(el.value) || 0 : 0;
    };
    const money = (n: number): string => '$' + Math.round(n).toLocaleString('en-US');
    const pct = (n: number): string => Math.round(n) + '%';
    const set = (id: string, value: string) => {
      const el = document.getElementById(id);
      if (el) el.textContent = value;
    };

    function calculate() {
      const workingWages = num('working_hours') * num('base_rate') + num('ot_hours') * num('ot_rate');
      const nonWorkingWages = (num('holiday_hours') + num('pto_hours') + num('sick_hours')) * num('base_rate');
      const taxableWages = workingWages + nonWorkingWages;

      const socialSecurity = taxableWages * 0.062;
      const medicare = taxableWages * 0.0145;
      const futa = Math.min(taxableWages, 7000) * 0.006; // FUTA: 0.6% on first $7,000

      const payrollTaxes = socialSecurity + medicare + futa + num('workers_comp') + num('state_unemployment');
      const benefits = num('retirement') + num('health_insurance');

      const annualTotal = workingWages + nonWorkingWages + payrollTaxes + benefits;
      const burdenCost = annualTotal - workingWages; // "Additional Cost Beyond Wages"

      const billableHours = num('working_hours') * num('efficiency');
      const breakEven = billableHours > 0 ? annualTotal / billableHours : 0;
      const hourlyCost = annualTotal / 2080; // fixed divisor, per live site
      const overheadPct = workingWages > 0 ? (burdenCost / workingWages) * 100 : 0;

      set('billable_hours', String(billableHours));
      set('break_even', money(breakEven));
      set('hourly_cost', money(hourlyCost));
      set('overhead_pct', pct(overheadPct));

      set('working_wages', money(workingWages));
      set('non_working_wages', money(nonWorkingWages));
      set('payroll_taxes', money(payrollTaxes));
      set('benefits_total', money(benefits));
      set('burden_cost', money(burdenCost));
      set('annual_total', money(annualTotal));
    }

    // Event delegation on the form covers every field; recalculate on load too.
    const form = document.getElementById('labor-form');
    if (form) {
      form.addEventListener('input', calculate);
      form.addEventListener('submit', (e) => e.preventDefault());
    }
    calculate();
  </script>

</BaseLayout>
