---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Site Credits" description="Website designed and developed by Deep River Digital.">
  <div class="container mx-auto px-4 py-16 prose">
    <h1>Site Credits</h1>
    <p>
      This website was designed and developed by <a href="https://deepriverdigital.com" target="_blank" rel="noopener noreferrer">Deep River Digital</a>.
    </p>
    <p>
      We specialize in high-performance web development for local businesses, focusing on speed, accessibility, and conversion optimization.
    </p>
    <h2>Technology Stack</h2>
    <ul>
        <li>Built with <a href="https://astro.build" target="_blank" rel="nofollow">Astro</a></li>
        <li>Styled with <a href="https://tailwindcss.com" target="_blank" rel="nofollow">Tailwind CSS</a></li>
        <!-- Components defined in global.css design system -->
        <li>Hosted on <a href="https://pages.cloudflare.com" target="_blank" rel="nofollow">Cloudflare Pages</a></li>
    </ul>
    <div class="not-prose mt-8">
        <a href="/" class="btn btn-outline">Back to Home</a>
    </div>
  </div>
</BaseLayout>
