---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DATA } from '../data/constants';

const { colors, fonts } = SITE_DATA.branding;
---

<BaseLayout title="Brand Guide">
  <div class="container mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold mb-8">Brand Guide: {SITE_DATA.company.name}</h1>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">Colors</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="space-y-2">
          <div class="h-24 w-full rounded shadow" style={`background-color: ${colors.primary};`}></div>
          <p class="font-bold">Primary</p>
          <code class="text-sm bg-base-200 px-2 py-1 rounded">{colors.primary}</code>
        </div>
        <div class="space-y-2">
          <div class="h-24 w-full rounded shadow" style={`background-color: ${colors.secondary};`}></div>
          <p class="font-bold">Secondary</p>
          <code class="text-sm bg-base-200 px-2 py-1 rounded">{colors.secondary}</code>
        </div>
        <div class="space-y-2">
          <div class="h-24 w-full rounded shadow" style={`background-color: ${colors.accent};`}></div>
          <p class="font-bold">Accent</p>
          <code class="text-sm bg-base-200 px-2 py-1 rounded">{colors.accent}</code>
        </div>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">Typography</h2>
      <div class="space-y-4">
        <div>
          <p class="text-sm text-base-content/70">Heading Font</p>
          <p class="text-3xl font-bold" style={`font-family: ${fonts.heading};`}>{fonts.heading}</p>
        </div>
        <div>
          <p class="text-sm text-base-content/70">Body Font</p>
          <p class="text-lg" style={`font-family: ${fonts.body};`}>{fonts.body} - The quick brown fox jumps over the lazy dog.</p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="text-2xl font-bold mb-4">Logos</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="border p-8 rounded flex items-center justify-center bg-white">
          <p class="text-gray-400 italic">Color Logo Placeholder</p>
        </div>
        <div class="border p-8 rounded flex items-center justify-center bg-black">
             <p class="text-gray-500 italic">White Logo Placeholder</p>
        </div>
        <div class="border p-8 rounded flex items-center justify-center bg-white">
             <p class="text-black italic">Black Logo Placeholder</p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
