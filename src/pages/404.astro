---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DATA } from '../data/constants';
---

<BaseLayout title="Page Not Found">
  <div class="grid min-h-[70vh] place-content-center bg-cream px-4">
    <div class="text-center">
      <h1 class="heading-display text-9xl text-base-300">404</h1>

      <p class="heading-display text-2xl text-primary sm:text-4xl mt-4">That page is off the books</p>

      <p class="mt-4 max-w-md mx-auto">We can't find the page you're looking for. It may have moved during our site rebuild.</p>

      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/" class="btn btn-accent">Go Back Home</a>
        <a href={SITE_DATA.links.bookACall} class="btn btn-outline">Book a Call</a>
      </div>
    </div>
  </div>
</BaseLayout>
