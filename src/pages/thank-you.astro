---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Thank You" description="Thank you for contacting us. We will get back to you shortly.">
  <div class="hero min-h-[60vh] bg-cream">
    <div class="hero-content text-center">
      <div class="max-w-md">
        <h1 class="heading-display text-5xl text-primary">Thank You!</h1>
        <p class="py-6">We have received your message and will be in touch shortly.</p>
        <a href="/" class="btn btn-accent">Return Home</a>
      </div>
    </div>
  </div>
</BaseLayout>
