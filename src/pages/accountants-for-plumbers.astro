---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import CalendlyEmbed from '../components/CalendlyEmbed.astro';

// Asset shared with the homepage — imported from home/, not duplicated
import ctaBgImg from '../assets/images/home/Footer-CTA-card-background.jpg';

// Page-specific images (downloaded from the live /accountants-for-plumbers/ page)
import heroImg from '../assets/images/pages/plumbing/Best-accountants-for-plumbers.webp';
import systemizeImg from '../assets/images/pages/plumbing/Accounting-for-plumbers.webp';
import growImg from '../assets/images/pages/plumbing/Accountants-for-plumbers.webp';

// Icons + testimonial photo shared by the electrical / plumbing / solar trade pages
import testimonialImg from '../assets/images/pages/shared/Ryann-Blake-Testimonial.jpg';
import popupImg from '../assets/images/pages/shared/Accounting-Team-for-Specialty-Trades.webp';
import icon360Financial from '../assets/images/pages/shared/360-financial-icon.svg';
import iconFileBox from '../assets/images/pages/shared/File-Box.svg';
import iconInvoice from '../assets/images/pages/shared/Invoice.svg';
import iconData from '../assets/images/pages/shared/Data.svg';
import iconCheck from '../assets/images/pages/shared/checkmark-accent.svg';
import iconCpu from '../assets/images/pages/shared/cpu-icon.svg';
import iconFinancial from '../assets/images/pages/shared/financial-icon.svg';
import iconDocCalc from '../assets/images/pages/shared/document-with-calculator.svg';
import iconTax from '../assets/images/pages/shared/tax-1.svg';
import iconWorkflow from '../assets/images/pages/shared/workflow.svg';

// Service cards. Unlike the electrical/solar pages, the live plumbing cards are NOT
// linked (the only "Learn More" pill carries a broken href and is hidden at every
// breakpoint), so these render as static cards.
const serviceCards = [
  { icon: iconFileBox, title: 'Monthly Bookkeeping' },
  { icon: iconInvoice, title: 'Monthly Payroll' },
  { icon: iconData, title: 'Bookkeeping for Tax Filing' },
];

// Benchmark assessment pills (live: three white pills on the orange band)
const assessmentQuestions = [
  'Is your growth where it should be?',
  'Are your business tools holding you back?',
  'Is it time for an accountant?',
];

// "Push you farther" icon boxes (live: row of three + centered row of two)
const capabilities = [
  { icon: iconCpu, title: 'Bring your technology up to speed' },
  { icon: iconFinancial, title: 'Manage & forecast cash flow' },
  { icon: iconDocCalc, title: 'Increase profitability through smarter accounting' },
  { icon: iconTax, title: 'Clean books that help your CPA capture every tax break' },
  { icon: iconWorkflow, title: 'Build better accounting workflows' },
];
---

<BaseLayout
  title="#1 Accountants for Plumbers | Bookkeeping | Tax | Payroll"
  description="Do you want an accountant who understands the plumbing industry? We're accountants for plumbers who actually grow your business. We provide comprehensive bookkeeping, financial strategy, cash flow forecasting, technology advice and more so that you get the expert financial advice you need..."
>

  {/* ── Hero (live: white bg, text 57% / image 42%) ── */}
  <section class="bg-base-100">
    <div class="container mx-auto px-4 py-14 md:py-20 grid gap-10 lg:grid-cols-[4fr_3fr] lg:items-center">
      <div>
        <h1 class="heading-display text-4xl md:text-5xl xl:text-6xl text-secondary">
          Work With The #1 <span class="text-sky-ink">Accountants for Plumbers</span>
        </h1>
        <p class="mt-6 text-lg leading-relaxed max-w-xl">
          Do you run out of cash mid-month? Unsure how to plan for growth? We’re accountants who understand the plumbing industry, and work with you to improve and grow your numbers.
        </p>
        <div class="mt-8">
          <a href="#calendly" class="btn btn-accent">Get Started Now</a>
        </div>
      </div>
      <div>
        <Image src={heroImg} alt="Accountants for plumbers" class="w-full h-auto block" widths={[480, 768, 900]} sizes="(min-width: 1024px) 40vw, 100vw" loading="eager" fetchpriority="high" />
      </div>
    </div>
  </section>

  {/* ── Overwhelmed? (live: navy band, centered) ── */}
  <section class="bg-primary">
    <div class="container mx-auto px-4 py-16 md:py-24 text-center">
      <h2 class="heading-display text-3xl md:text-5xl text-white max-w-4xl mx-auto">
        Do You Feel Overwhelmed In <span class="text-sky">Your Plumbing Business?</span>
      </h2>
      <p class="mt-6 text-lg leading-relaxed text-white/90 max-w-4xl mx-auto">
        At Atlas Accounting Group, we believe that accountants should do more than just run the numbers each month. Our job is to help you become a smarter business owner – by understanding when and how to grow, bring clarity to numbers, and help find opportunities to grow.
      </p>
    </div>
  </section>

  {/* ── Services (live: cream body bg, centered heading, orange card + 3 white cards, 2px gaps, no links) ── */}
  <section class="bg-cream">
    <div class="container mx-auto px-4 py-16 md:py-24">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="heading-display text-3xl md:text-5xl text-secondary">
          Get Clarity on <span class="text-sky-ink">Every Aspect Of Your Business</span>
        </h2>
        <p class="mt-5 text-lg leading-relaxed">
          With the right team of accountants on your side, you should be able to define and surpass your loftiest financial goals.
        </p>
      </div>
      <div class="mt-12 grid gap-0.5 sm:grid-cols-2 lg:grid-cols-4">
        {/* Card 1 — orange. Navy title (live white fails contrast on orange). */}
        <div class="bg-accent px-6 py-12 flex flex-col items-center text-center">
          <Image src={icon360Financial} alt="" class="h-[70px] w-auto" width={70} height={70} aria-hidden="true" />
          <h3 class="text-2xl font-bold text-primary mt-6">Financial Advisory</h3>
        </div>
        {/* Cards 2–4 — white, static on the live page */}
        {serviceCards.map((card) => (
          <div class="bg-base-100 border border-base-300 hover:border-accent transition-colors px-6 py-12 flex flex-col items-center text-center">
            <Image src={card.icon} alt="" class="h-[70px] w-auto" width={70} height={70} aria-hidden="true" />
            <h3 class="text-2xl font-bold text-secondary mt-6">{card.title}</h3>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ── Systemize (live: white, text left / image right) ── */}
  <section class="bg-base-100">
    <div class="container mx-auto px-4 py-16 md:py-24 grid gap-12 lg:grid-cols-2 lg:items-center">
      <div>
        <h2 class="heading-display text-3xl md:text-5xl text-secondary">
          <span class="text-sky-ink">Systemize</span> Your Plumbing Business
        </h2>
        <p class="mt-6 leading-relaxed">
          Are you stressed about cash flow – not knowing how much money will be coming into and out of the business, and when? Do you feel like you’re always running around putting out fires because you don’t have a comprehensive and strategic plan in place? At Atlas Accounting Group, we help you systemize your business through automated technology, real-time data, and improved internal workflows so you always have a grip on the full picture of your business.
        </p>
      </div>
      <Image src={systemizeImg} alt="" class="w-full h-auto" widths={[480, 768, 900]} sizes="(min-width: 1024px) 45vw, 100vw" aria-hidden="true" />
    </div>

    {/* ── Grow (live: white, image left / text right).
         Live heading says "grow your construction business" — copy-paste error, localized to plumbing. ── */}
    <div class="container mx-auto px-4 pb-16 md:pb-24 grid gap-12 lg:grid-cols-2 lg:items-center">
      <Image src={growImg} alt="#1 accountants for plumbers" class="w-full h-auto order-last lg:order-first" widths={[480, 768, 900]} sizes="(min-width: 1024px) 45vw, 100vw" />
      <div>
        <h2 class="heading-display text-3xl md:text-5xl text-secondary">
          Find Opportunities to <span class="text-sky-ink">grow your plumbing business</span>
        </h2>
        <p class="mt-6 leading-relaxed">
          We aren’t afraid to say that your accountant should help you grow your business, not just manage it. We’ll dive into your business to pull out any low-hanging revenue opportunities we see, find ways to cut down on unnecessary expenses, and help you manage your money in a way that brings in more profits month-on-month.
        </p>
      </div>
    </div>
  </section>

  {/* ── Benchmark assessment (live: orange band; navy text kept for WCAG contrast on orange) ── */}
  <section class="bg-accent">
    <div class="container mx-auto px-4 py-16 md:py-24">
      <div class="max-w-3xl mx-auto text-center">
        <p class="eyebrow text-primary mb-4">Get Your Benchmark Assessment</p>
        <h2 class="heading-display text-3xl md:text-5xl text-primary">
          How does Your Plumbing business stack up?
        </h2>
        <p class="mt-4 text-2xl font-medium text-primary">Let’s assess…</p>
      </div>
      <ul class="mt-12 grid gap-4 md:gap-10 lg:grid-cols-3 max-w-5xl mx-auto" role="list">
        {assessmentQuestions.map((q) => (
          <li class="flex items-start gap-4 bg-base-100 px-5 py-3.5">
            <Image src={iconCheck} alt="" class="h-10 w-10 shrink-0" width={42} height={42} aria-hidden="true" />
            <span class="text-xl md:text-2xl font-bold text-secondary">{q}</span>
          </li>
        ))}
      </ul>
      <div class="mt-12 text-center">
        <a href="#calendly" class="btn btn-primary">Book Your Discovery Call</a>
      </div>
    </div>
  </section>

  {/* ── Push you farther (live: white, centered icon boxes — row of 3 + centered row of 2 — then button) ── */}
  <section class="bg-base-100">
    <div class="container mx-auto px-4 py-16 md:py-24">
      <h2 class="heading-display text-3xl md:text-5xl text-secondary text-center max-w-4xl mx-auto">
        Work with Plumbing accountants <span class="text-sky-ink">who push you farther</span>
      </h2>
      <div class="mt-14 flex flex-wrap justify-center gap-x-10 gap-y-12">
        {capabilities.map((cap) => (
          <div class="w-full text-center sm:w-[calc(50%-1.25rem)] lg:w-[calc(33.333%-1.75rem)]">
            <Image src={cap.icon} alt="" class="h-20 w-auto mx-auto" width={85} height={85} aria-hidden="true" />
            <h3 class="heading-display text-lg md:text-xl text-secondary mt-6">{cap.title}</h3>
          </div>
        ))}
      </div>
      <div class="mt-12 text-center">
        <a href="/why-we-are-different/" class="btn btn-accent">What's It Like To Work With Us?</a>
      </div>
    </div>
  </section>

  {/* ── Testimonial (live: cream body bg, photo w/ name overlay + quote) ── */}
  <section class="bg-cream">
    <div class="container mx-auto px-4 py-16 md:py-24 grid gap-12 lg:grid-cols-[9fr_11fr] lg:items-center">
      <div class="relative">
        <Image src={testimonialImg} alt="Ryann Blake Testimonial" class="w-full h-auto" widths={[420, 525]} sizes="(min-width: 1024px) 40vw, 100vw" />
        {/* Live overlays the name bottom-left in white; gradient added so the text passes contrast */}
        <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/70 to-transparent pt-16 pb-6 px-8">
          <p class="heading-display text-2xl md:text-3xl text-white">Ryann Blake</p>
          <p class="text-white text-lg uppercase">Owner of Chimney Techniques</p>
        </div>
      </div>
      <figure>
        <blockquote>
          <p class="heading-display text-3xl md:text-4xl text-secondary">
            “I now have a <span class="text-sky-ink">full understanding</span> of my financial position.”
          </p>
          <p class="mt-6 leading-relaxed">
            Working with Atlas Accounting Group has completely changed the outlook of my business. When we started our partnership, I knew very little about the financial health of my company. Like many small business owners, I had a family member overseeing everything. When retirement forced a change, Alysia took the reins and because of her I now have a full understanding of my financial position and am able to make educated business decisions instead of basing them on guesses and feelings.
          </p>
        </blockquote>
        <figcaption class="sr-only">Ryann Blake, Owner of Chimney Techniques</figcaption>
      </figure>
    </div>
  </section>

  {/* ── Book a call (live: footer template band — orange duotone photo + Calendly).
       Live heading says "construction business" on every page → localized per trade. ── */}
  <section id="calendly" class="bg-accent relative overflow-hidden scroll-mt-24">
    <Image src={ctaBgImg} alt="" class="absolute inset-0 w-full h-full object-cover object-top" widths={[1280]} sizes="100vw" aria-hidden="true" />
    <div class="absolute inset-0 bg-gradient-to-b from-black/25 to-transparent pointer-events-none"></div>
    <div class="container mx-auto px-4 py-16 md:py-20 relative">
      <h2 class="heading-display text-3xl md:text-4xl text-white text-center max-w-3xl mx-auto">
        Find out how we can help your plumbing business
      </h2>
      <div class="mt-10 max-w-3xl mx-auto bg-base-100 shadow-xl">
        <CalendlyEmbed />
      </div>
    </div>
  </section>

  {/*
    Profit Margin Calculator popup — recreation of the live Elementor popup (id 666),
    which also shows on this page: slides in once per session, non-modal.
    Kept inline (no new shared components); pattern mirrors hvac-accounting.astro.
  */}
  <div
    class="pm-popup fixed z-[60] bg-primary shadow-2xl hidden inset-x-0 bottom-0 w-full md:inset-x-auto md:right-6 md:bottom-6 md:w-[22rem]"
    role="dialog"
    aria-label="Try our free Profit Margin Calculator"
    data-pm-popup
  >
    <button
      type="button"
      class="absolute top-3 right-3 z-10 inline-flex items-center justify-center h-9 w-9 text-white hover:text-accent transition-colors focus-visible:outline-2 focus-visible:outline-accent"
      data-pm-popup-close
    >
      <span class="sr-only">Close</span>
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" d="M6 6l12 12M18 6L6 18" />
      </svg>
    </button>
    <div class="p-6 px-10 text-center">
      <p class="heading-display text-xl text-white">Try our free Profit Margin Calculator</p>
      <p class="mt-2 text-white/85 text-sm">Estimate your project margins with ease.</p>
      <a href="/profit-margin-calculator/" class="btn btn-accent mt-4 w-full">Try Now</a>
    </div>
    <Image src={popupImg} alt="" class="w-full h-28 md:h-40 object-cover" widths={[420, 768]} sizes="(min-width: 768px) 22rem, 100vw" loading="lazy" aria-hidden="true" />
  </div>

</BaseLayout>

<style>
  .pm-popup {
    opacity: 0;
    /* mobile: slide up from the bottom edge */
    transform: translateY(100%);
    transition: transform 0.6s ease-out, opacity 0.6s ease-out;
  }
  @media (min-width: 768px) {
    /* desktop: slide in from the right edge (live: fadeInRight) */
    .pm-popup {
      transform: translateX(calc(100% + 1.5rem));
    }
  }
  .pm-popup.pm-popup-open {
    opacity: 1;
    transform: translate(0, 0);
  }
  @media (prefers-reduced-motion: reduce) {
    .pm-popup {
      transition: opacity 0.2s ease-out;
      transform: none;
    }
  }
</style>

<script>
  const popup = document.querySelector<HTMLElement>('[data-pm-popup]');
  const closeBtn = document.querySelector<HTMLButtonElement>('[data-pm-popup-close]');
  const KEY = 'atlas-pm-popup-shown';

  if (popup && closeBtn && !sessionStorage.getItem(KEY)) {
    // Slight delay so the popup doesn't compete with the initial page render
    setTimeout(() => {
      sessionStorage.setItem(KEY, '1');
      popup.classList.remove('hidden');
      // force a reflow so the entrance transition runs from the off-screen state
      void popup.offsetHeight;
      popup.classList.add('pm-popup-open');
    }, 2500);

    const close = () => {
      popup.classList.remove('pm-popup-open');
      let removed = false;
      const remove = () => {
        if (removed) return;
        removed = true;
        popup.remove();
      };
      popup.addEventListener('transitionend', remove, { once: true });
      setTimeout(remove, 700); // fallback (e.g. prefers-reduced-motion)
    };

    closeBtn.addEventListener('click', close);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && popup.isConnected && popup.classList.contains('pm-popup-open')) close();
    });
  }
</script>
