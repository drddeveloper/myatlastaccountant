---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/sections/PageHero.astro';
import SectionHeading from '../components/sections/SectionHeading.astro';
import CtaBand from '../components/sections/CtaBand.astro';
import Testimonial from '../components/sections/Testimonial.astro';
import { SITE_DATA } from '../data/constants';

const services = [
  { title: 'Financial Advisory', href: '/why-we-are-different/', blurb: 'A partner who studies your numbers with you and helps you decide when to hire, buy, and expand.' },
  { title: 'Monthly Bookkeeping', href: '/pricing/', blurb: 'Books closed on time every month, so you always know how the company is really doing.' },
  { title: 'Monthly Payroll', href: '/construction-payroll/', blurb: 'Plumbers and office staff paid right and on time — wages, taxes, and filings handled.' },
  { title: 'Bookkeeping for Tax Filing', href: '/tax-services/', blurb: 'Tax-ready books all year, so filing season is quick and nothing gets missed.' },
];

const assessmentQuestions = [
  'Is your growth where it should be?',
  'Are your business tools holding you back?',
  'Is it time for an accountant?',
];

const differentiators = [
  { title: 'Bring your technology up to speed', body: 'Your dispatch and invoicing software connected straight to the books — no double entry.' },
  { title: 'Manage & forecast cash flow', body: 'Know weeks ahead when cash will run tight, and plan around it instead of reacting to it.' },
  { title: 'Increase profitability through smarter accounting', body: 'Find the jobs and cost lines quietly draining your margin — and fix them.' },
  { title: 'Clean books that help your CPA capture every tax break', body: 'Organized, current books mean deductions get claimed instead of forgotten.' },
  { title: 'Build better accounting workflows', body: 'A back office that runs the same reliable way every month as the company grows.' },
];
---

<BaseLayout
  title="#1 Accountants for Plumbers | Bookkeeping | Tax | Payroll"
  description="Want an accountant who understands the plumbing industry? Atlas Accounting Group provides bookkeeping, payroll, cash flow forecasting, and financial strategy that actually grow your plumbing business."
>

  <PageHero
    theme="navy"
    eyebrow="Accountants for Plumbers"
    title="Work with the #1 accountants for Plumbers"
    subtitle="Cash flow feels unpredictable and growth planning keeps sliding to next quarter. We know the plumbing industry — and we turn messy financials into a clear plan for a more profitable company."
    ctaLabel="Get Started Now"
    ctaHref={SITE_DATA.links.bookACall}
    secondaryLabel="See Pricing"
    secondaryHref="/pricing/"
  />

  <section class="bg-base-100">
    <div class="container mx-auto px-4 py-16 md:py-24">
      <div class="max-w-3xl">
        <SectionHeading
          eyebrow="Sound familiar?"
          title="Do you feel overwhelmed in your plumbing business?"
        />
        <div class="mt-6 space-y-5 text-lg leading-relaxed">
          <p>An accountant who only "runs the numbers" isn't doing enough. The right one makes you a smarter owner — you learn when the business is genuinely ready to grow, what your financials are actually telling you, and where the opportunities are hiding. That clarity is the difference between running a plumbing company and being run by it.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-cream">
    <div class="container mx-auto px-4 py-16 md:py-24">
      <SectionHeading
        eyebrow="Services"
        title="Get clarity on every aspect of your business"
        intro="Your financial goals are reachable — with the right accounting support behind them."
      />
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {services.map((s) => (
          <a href={s.href} class="card border border-base-300 shadow-none hover:border-accent hover:shadow-lg transition-shadow group focus-visible:outline-2 focus-visible:outline-accent">
            <h3 class="heading-display text-lg text-primary group-hover:text-accent-ink transition-colors">{s.title}</h3>
            <p class="mt-3 text-sm leading-relaxed">{s.blurb}</p>
            <span class="mt-4 inline-block text-accent-ink font-semibold text-sm uppercase tracking-wide">Learn more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-base-100">
    <div class="container mx-auto px-4 py-16 md:py-24 grid gap-12 lg:grid-cols-2 lg:items-center">
      <SectionHeading
        eyebrow="Systemize"
        title="Systemize your plumbing business"
        intro="Cash flow stress and operational chaos usually share a root cause: no system. We put automation, real-time data, and clean workflows behind your back office so you finally have full visibility into the business."
      />
      <div class="card bg-cream shadow-none border border-base-300">
        <h3 class="heading-display text-lg text-primary">What changes with a system</h3>
        <ul class="mt-4 space-y-3" role="list">
          <li class="flex items-start gap-3"><span class="text-accent font-bold" aria-hidden="true">→</span>Books closed on the same schedule every month</li>
          <li class="flex items-start gap-3"><span class="text-accent font-bold" aria-hidden="true">→</span>Cash position you can check any day of the week</li>
          <li class="flex items-start gap-3"><span class="text-accent font-bold" aria-hidden="true">→</span>Field software and accounting software finally in sync</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="bg-primary">
    <div class="container mx-auto px-4 py-16 md:py-24">
      <div class="max-w-3xl">
        <SectionHeading
          onDark
          eyebrow="Grow"
          title="Find opportunities to grow your plumbing business"
          intro="We're growth mentors, not just managers. That means identifying revenue you're missing, cutting expenses that don't earn their keep, and tightening cash management so more of every job becomes profit."
        />
        <div class="mt-8">
          <a href={SITE_DATA.links.bookACall} class="btn btn-accent">Get Your Benchmark Assessment</a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-cream">
    <div class="container mx-auto px-4 py-16 md:py-24">
      <div class="max-w-3xl mx-auto text-center">
        <SectionHeading
          eyebrow="Quick check"
          title="How does your plumbing business stack up?"
          align="center"
        />
        <ul class="mt-8 space-y-4 text-left max-w-md mx-auto" role="list">
          {assessmentQuestions.map((q) => (
            <li class="flex items-start gap-3 text-lg font-semibold text-primary">
              <svg class="h-6 w-6 shrink-0 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01" />
              </svg>
              {q}
            </li>
          ))}
        </ul>
        <div class="mt-10">
          <a href={SITE_DATA.links.bookACall} class="btn btn-accent">Book Your Discovery Call</a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-base-100">
    <div class="container mx-auto px-4 py-16 md:py-24">
      <SectionHeading
        eyebrow="Why Atlas"
        title="Work with plumbing accountants who push you farther"
      />
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {differentiators.map((d) => (
          <div class="card bg-cream shadow-none border border-base-300">
            <h3 class="heading-display text-lg text-primary">{d.title}</h3>
            <p class="mt-3 text-sm leading-relaxed">{d.body}</p>
          </div>
        ))}
      </div>
      <div class="mt-10">
        <a href="/why-we-are-different/" class="btn btn-outline">What's It Like To Work With Us?</a>
      </div>
    </div>
  </section>

  <section class="bg-cream">
    <div class="container mx-auto px-4 py-16 md:py-24">
      <div class="max-w-3xl mx-auto">
        <Testimonial
          quote="I now have a full understanding of my financial position."
          name="Ryann Blake"
          role="Owner, Chimney Techniques"
        />
      </div>
    </div>
  </section>

  <CtaBand
    heading="Find out how we can help your plumbing business"
    subtext="Book a free discovery call and see what a real financial partner looks like for your plumbing company."
    ctaLabel="Book Your Discovery Call"
  />

</BaseLayout>
